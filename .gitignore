# ── macOS ────────────────────────────────────────────────────────────────────
# Arquivos de metadados do macOS (gerados pelo Finder/rsync/cp em HFS+/APFS)
._*
**/._*
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── IDEs e editores ───────────────────────────────────────────────────────────
.idea/
.vscode/
.qodo/
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.env
.venv/
venv/

# ── Dados gerados pelo pipeline ──────────────────────────────────────────────
# downloads/ é versionado intencionalmente: contém as transcrições que
# constituem o corpus primário da dissertação de mestrado (PPGCTS/UFSCar).
# Apenas os metadados intermediários e saídas de organização são ignorados.
data/
organized/

# ── Arquivos de legenda brutos (SRT/VTT) ─────────────────────────────────────
# Gerados apenas quando --keep-subs é passado; são artefatos intermediários
*.srt
*.vtt

# ── Arquivos temporários ──────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
tmp/
